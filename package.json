{
  "name": "kiduna-studio-prototype",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ignore-pattern .next",
    "db:up": "docker-compose up -d --build postgres",
    "db:down": "docker-compose down",
    "db:check": "node --env-file=.env.local scripts/db-check.mjs",
    "db:seed": "node --env-file=.env.local scripts/db-seed.mjs",
    "db:ingest:ki": "node --env-file=.env.local scripts/ingest-ki-wisdom.mjs",
    "db:seed:owner": "node --env-file=.env.local scripts/seed-prototype-owner.mjs",
    "db:generate": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs migrate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "typescript": "5.9.3"
  },
  "type": "module"
}
