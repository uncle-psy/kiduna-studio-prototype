{
  "name": "studio",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "check": "tsc --noEmit",
    "payload": "cross-env PAYLOAD_CONFIG_PATH=payload.config.ts payload",
    "payload:migrate": "tsx payload-migrate.mts",
    "payload:migrate:create": "npm run payload migrate:create",
    "payload:seed": "tsx payload-seed.ts",
    "payload:generate": "npm run payload generate:types && npm run payload generate:importmap",
    "postinstall": "node -e \"try{require('fs').rmSync('./node_modules/payload/node_modules/tsx',{recursive:true,force:true})}catch(e){}\""
  },
